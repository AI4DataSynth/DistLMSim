#!/usr/bin/expect -f
# SSH 自动登录脚本
# 用法: ./ssh_setup.exp <host> <command>

set host [lindex $argv 0]
set user "shengxiang"
set password "xiangsheng218"
set cmd [lindex $argv 1]

set timeout 30

spawn ssh -o StrictHostKeyChecking=no $user@$host $cmd
expect {
    "yes/no" {
        send "yes\r"
        expect "assword:"
        send "$password\r"
    }
    "assword:" {
        send "$password\r"
    }
}
expect eof
catch wait result
exit [lindex $result 3]
